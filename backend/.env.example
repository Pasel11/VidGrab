# VidGrab API Environment Variables
# Copy this file to .env and fill in your values

NODE_ENV=production
PORT=3000

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this

# Rate Limiting
RATE_LIMIT_MAX=100
DOWNLOAD_RATE_LIMIT=10

# CORS
ALLOWED_ORIGINS=https://your-app.com,http://localhost:*

# Redis (optional, for caching)
REDIS_URL=redis://redis:6379

# In-App Purchase (optional)
APPLE_SHARED_SECRET=
GOOGLE_PLAY_LICENSE_KEY=

# Analytics (optional)
MIXPANEL_TOKEN=
AMPLITUDE_API_KEY=